# Copy this file to `.env` and fill in your values. `.env` is gitignored.
# Every setting is optional except a provider API key for your chosen model.

# --- Model & provider -------------------------------------------------------
# Any LiteLLM model string. Examples:
#   anthropic/claude-sonnet-4-6   (needs ANTHROPIC_API_KEY)
#   openai/gpt-4o                 (needs OPENAI_API_KEY)
#   gemini/gemini-1.5-pro         (needs GEMINI_API_KEY)
#   ollama_chat/llama3            (local Ollama, no key)
DP_CORE_MODEL=anthropic/claude-sonnet-4-6
DP_MAX_TOKENS=2048

# Cap on the episodic log; it is trimmed to the most recent N entries (0 disables).
DP_MAX_EPISODES=2000
# Facts whose salience decays below this are forgotten on consolidation (0 disables).
DP_SALIENCE_FLOOR=0.05

# Provider API key (set the one matching DP_CORE_MODEL).
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# Optional: custom endpoint (e.g. Ollama Cloud, a proxy). DP_API_KEY falls back
# to OLLAMA_CLOUD_API_KEY if set.
# DP_API_BASE=
# DP_API_KEY=
# OLLAMA_CLOUD_API_KEY=

# --- Runtime data -----------------------------------------------------------
# Where memory, audit log, vector index and sandbox workspace are stored.
# Defaults to $XDG_DATA_HOME/paulus (i.e. ~/.local/share/paulus).
# DP_DATA_DIR=/var/lib/paulus

# --- Proactive (idle) outreach ----------------------------------------------
# Idleness is tracked per user. When a user has been quiet for DP_MIN_IDLE
# minutes, the agent may send an unprompted check-in (it can also stay silent).
# How often (seconds) to scan for idle users. 0 disables proactive outreach.
DP_IDLE_CHECK=300
# Minutes of silence before a user becomes eligible for a nudge.
DP_MIN_IDLE=30
# Max unprompted messages per user before they speak again (resets on reply).
DP_MAX_IDLE_MSG=3
# Local-time quiet window (24h, START-END) during which no nudges are sent;
# wraps midnight if START > END. Empty disables. e.g. 23-7 mutes 23:00–07:00.
# DP_QUIET_HOURS=23-7

# --- Sandbox ----------------------------------------------------------------
# Command/file execution backend: local | docker | ssh
DP_SANDBOX=local
DP_CMD_TIMEOUT=30
# DP_DOCKER_IMAGE=python:3.12-slim
# DP_SSH_TARGET=user@host
# DP_SSH_REMOTE_DIR=~/dp-workspace

# --- Safety -----------------------------------------------------------------
# What to do with a high-impact action (write file / run command / send
# message) when no one can be asked to approve it (e.g. running as a service
# with no reachable user): deny (default, fail safe) | approve
DP_UNATTENDED_POLICY=deny
# Let a reachable, trusted gateway user approve high-impact actions
# interactively (Telegram Approve/Deny buttons) instead of falling straight to
# the policy above. On by default; set to 0 to disable. Unanswered prompts time
# out to a safe DENY after DP_APPROVAL_TIMEOUT seconds.
# DP_GATEWAY_APPROVALS=1
# DP_APPROVAL_TIMEOUT=300

# --- Telegram gateway (only needed for `paulus-gateway`) --------------------
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# Who may CHAT with the bot: comma-separated numeric Telegram user IDs.
# Empty/unset = everyone. Non-listed users are turned away.
# TELEGRAM_ALLOWED_USERS=123456789,987654321
# Who may APPROVE high-impact actions (write file / run command / send message).
# Use this to keep the chat open to all but restrict high-impact actions to a
# few trusted IDs. Unset = same as TELEGRAM_ALLOWED_USERS; set but empty = nobody
# can approve (high-impact actions then follow DP_UNATTENDED_POLICY).
# TELEGRAM_TRUSTED_USERS=123456789
# Outbound formatting: MarkdownV2 (default) renders the model's Markdown;
# set to plain/none/off for raw text. Markdown needs the `telegram` extra.
# TELEGRAM_PARSE_MODE=MarkdownV2
# Stream replies by live-editing one message as the model writes (default on).
# Set to 0/off for one-shot delivery once the full reply is ready.
# TELEGRAM_STREAMING=1
