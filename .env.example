# Copy this file to `.env` and fill in your values. `.env` is gitignored.
# Every setting is optional except a provider API key for your chosen model.

# --- Model & provider -------------------------------------------------------
# Any LiteLLM model string. Examples:
#   anthropic/claude-sonnet-4-6            (needs ANTHROPIC_API_KEY)
#   openai/gpt-4o                          (needs OPENAI_API_KEY)
#   gemini/gemini-1.5-pro                  (needs GEMINI_API_KEY)
#   openrouter/anthropic/claude-sonnet-4-6 (needs OPENROUTER_API_KEY)
#   ollama_chat/llama3                     (local Ollama, no key)
DP_CORE_MODEL=anthropic/claude-sonnet-4-6
DP_MAX_TOKENS=2048

# --- Model routing (optional, off by default) --------------------------------
# DP_CORE_MODEL is the FLOOR: every turn runs on it unless the router finds
# positive evidence the turn needs more (a traceback, a code fence, an attached
# document, a long input, or an escalation-shaped question). Routing only ever
# escalates upward, so it buys quality rather than saving cost, and any failure
# falls back to DP_CORE_MODEL — i.e. exactly the behaviour with routing off.
# Needs the `vectors` extra (chromadb) for the semantic pass; without it the
# structural signals still work and everything else stays on the core model.
# DP_ROUTING=semantic
# Unset tiers collapse into the one below, so two tiers is just DP_TOP_MODEL.
# DP_MID_MODEL=openrouter/openai/gpt-4o-mini
# DP_TOP_MODEL=openrouter/anthropic/claude-opus-4-8
# Internal strict-JSON jobs (consolidation, fact reconciliation) are pinned,
# never routed. Defaults to DP_CORE_MODEL. Point it at a stronger model if
# consolidation is producing unparseable JSON.
# DP_UTILITY_MODEL=
# Minimum cosine margin over the runner-up tier before an escalation is
# trusted; below it the turn falls back DOWN a tier. Raise to escalate less.
# Use the CLI's `/route <text>` to see what a given phrasing resolves to.
# DP_ROUTE_MARGIN=0.08

# Routing feedback. Every decision is logged with its outcome (per user, next
# to their memory); `/routes` shows them. An under-route looks like a row that
# was routed low and then had to reach outside the agent's own memory.
# Cap on that log; trimmed to the most recent N events (0 disables).
# DP_MAX_ROUTE_LOG=2000
# Learning promotes the phrasings behind under-routes into the exemplar bank,
# one tier up, so the same wording escalates next time. OFF by default: it
# feeds real user text back into routing, and a wrong promotion drags small
# talk upward — degrading the floor. Watch `/routes` on real traffic first.
# DP_ROUTE_LEARNING=1
# Cap on learned exemplars per tier per user; oldest evicted first, so a bad
# promotion ages out. Delete a user's route_exemplars.json to reset.
# DP_MAX_LEARNED=40

# Cap on the episodic log; it is trimmed to the most recent N entries (0 disables).
DP_MAX_EPISODES=2000
# Facts whose salience decays below this are forgotten on consolidation (0 disables).
DP_SALIENCE_FLOOR=0.05

# Provider API key (set the one matching DP_CORE_MODEL).
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# One OpenRouter key reaches models from every provider it proxies, so an
# openrouter/* model needs only this key regardless of who made the model.
# OPENROUTER_API_KEY=

# Optional: custom endpoint for DP_CORE_MODEL (e.g. Ollama Cloud, a proxy).
# DP_API_KEY falls back to OLLAMA_CLOUD_API_KEY if set.
# NOTE: this pair describes ONE endpoint, so it is applied to DP_CORE_MODEL
# only. Models called with an explicit override take their credentials from
# their own provider key above instead.
# DP_API_BASE=
# DP_API_KEY=
# OLLAMA_CLOUD_API_KEY=

# --- Web access -------------------------------------------------------------
# `web_search` and `fetch_url` let the agent research the live web. Search works
# with no key via DuckDuckGo; set a key below for a higher-quality provider.
# DP_SEARCH_PROVIDER: auto (default) | duckduckgo | tavily | brave
# DP_SEARCH_PROVIDER=auto
# TAVILY_API_KEY=
# BRAVE_API_KEY=
# Result/size limits for the web tools.
# DP_WEB_MAX_RESULTS=5
# DP_WEB_MAX_CHARS=8000
# DP_WEB_TIMEOUT=20

# --- Runtime data -----------------------------------------------------------
# Where memory, audit log, vector index and sandbox workspace are stored.
# Defaults to $XDG_DATA_HOME/paulus (i.e. ~/.local/share/paulus).
# DP_DATA_DIR=/var/lib/paulus

# --- Proactive (idle) outreach ----------------------------------------------
# Idleness is tracked per user. When a user has been quiet for DP_MIN_IDLE
# minutes, the agent may send an unprompted check-in (it can also stay silent).
# How often (seconds) to scan for idle users. 0 disables proactive outreach.
DP_IDLE_CHECK=300
# Minutes of silence before a user becomes eligible for a nudge.
DP_MIN_IDLE=30
# Max unprompted messages per user before they speak again (resets on reply).
DP_MAX_IDLE_MSG=3
# Local-time quiet window (24h, START-END) during which no nudges are sent;
# wraps midnight if START > END. Empty disables. e.g. 23-7 mutes 23:00–07:00.
# DP_QUIET_HOURS=23-7

# --- Sandbox ----------------------------------------------------------------
# Command/file execution backend: local | docker | ssh
DP_SANDBOX=local
DP_CMD_TIMEOUT=30
# DP_DOCKER_IMAGE=python:3.12-slim
# DP_SSH_TARGET=user@host
# DP_SSH_REMOTE_DIR=~/dp-workspace

# --- Safety -----------------------------------------------------------------
# What to do with a high-impact action (write file / run command / send
# message) when no one can be asked to approve it (e.g. running as a service
# with no reachable user): deny (default, fail safe) | approve
DP_UNATTENDED_POLICY=deny
# Let a reachable, trusted gateway user approve high-impact actions
# interactively (Telegram Approve/Deny buttons) instead of falling straight to
# the policy above. On by default; set to 0 to disable. Unanswered prompts time
# out to a safe DENY after DP_APPROVAL_TIMEOUT seconds.
# DP_GATEWAY_APPROVALS=1
# DP_APPROVAL_TIMEOUT=300

# --- Billing (usage pay gate) ------------------------------------------------
# Optional. Balance, transactions and per-message pricing all live in an
# external billing service. When set, gateway users are checked against it
# before each LLM turn and blocked once their balance runs out; CLI /
# single-owner mode is never gated. Unset (default) = gate disabled.
# DP_BILLING_API_BASE=https://payment.example.com/paulus
# DP_BILLING_CHECK_PATH=/usage/check
# DP_BILLING_API_KEY=
# DP_BILLING_TIMEOUT=10
# Fallback top-up link shown as a button with the insufficient-balance message
# (Telegram; other adapters append it as a plain URL) when the check-usage
# response doesn't include its own "payment_url". "{user_id}" is substituted
# if present. Unset = no link/button when the response doesn't supply one.
# DP_BILLING_TOPUP_URL=https://payment.example.com/paulus/topup?user={user_id}

# --- Telegram gateway (only needed for `paulus-gateway`) --------------------
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# Who may CHAT with the bot: comma-separated numeric Telegram user IDs.
# Empty/unset = everyone. Non-listed users are turned away.
# TELEGRAM_ALLOWED_USERS=123456789,987654321
# Who may APPROVE high-impact actions (write file / run command / send message).
# Use this to keep the chat open to all but restrict high-impact actions to a
# few trusted IDs. Unset = same as TELEGRAM_ALLOWED_USERS; set but empty = nobody
# can approve (high-impact actions then follow DP_UNATTENDED_POLICY).
# TELEGRAM_TRUSTED_USERS=123456789
# Outbound formatting: MarkdownV2 (default) renders the model's Markdown;
# set to plain/none/off for raw text. Markdown needs the `telegram` extra.
# TELEGRAM_PARSE_MODE=MarkdownV2
# Stream replies by live-editing one message as the model writes (default on).
# Set to 0/off for one-shot delivery once the full reply is ready.
# TELEGRAM_STREAMING=1
