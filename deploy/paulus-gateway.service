# systemd unit for the PaulusAI Telegram gateway.
#
# Install (as the dedicated `paulus` user created in the README):
#   sudo cp deploy/paulus-gateway.service /etc/systemd/system/
#   sudo systemctl daemon-reload
#   sudo systemctl enable --now paulus-gateway
#
# Logs:   journalctl -u paulus-gateway -f
# Status: systemctl status paulus-gateway

[Unit]
Description=PaulusAI Telegram gateway
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=paulus
Group=paulus

# Secrets and configuration. The file must contain ANTHROPIC_API_KEY (or the
# key for your chosen provider) and TELEGRAM_BOT_TOKEN. Keep it 0600.
EnvironmentFile=/etc/paulus/paulus.env

# Where runtime memory / audit log / vector index / workspace are written.
Environment=DP_DATA_DIR=/var/lib/paulus
# The dedicated user's home (/opt/paulus) is read-only under ProtectSystem=strict,
# but Chroma caches its local embedding model under ~/.cache/chroma. Point HOME at
# the writable state dir so that cache (and any other ~/.cache use) can be written;
# otherwise reindexing fails and memory silently degrades to keyword search.
Environment=HOME=/var/lib/paulus
# No interactive console here, so high-impact tools fail safe (deny) by default.
Environment=DP_UNATTENDED_POLICY=deny
# Unbuffer stdout/stderr so the startup banner and prints reach journald
# immediately (otherwise Python block-buffers when stdout is a pipe, not a tty).
Environment=PYTHONUNBUFFERED=1

ExecStart=/opt/paulus/venv/bin/paulus-gateway
Restart=on-failure
RestartSec=5

# --- Hardening --------------------------------------------------------------
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
PrivateTmp=true
ReadWritePaths=/var/lib/paulus

[Install]
WantedBy=multi-user.target
