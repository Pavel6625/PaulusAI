# --- Django -----------------------------------------------------------------
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Browser origins allowed to call the API (the Mini App's origin).
DJANGO_CORS_ORIGINS=https://your-mini-app.example.com

# --- Telegram ---------------------------------------------------------------
# Bot whose Mini App drives payments; also verifies WebApp initData.
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# --- TON / USD₮ -------------------------------------------------------------
# Receiving wallet in FRIENDLY form (EQ…/UQ…) — recipient for both TON and USD₮.
# NOTE: PaulusAI must be configured with the SAME wallet in raw "0:<hex>" form.
TON_WALLET_ADDRESS=EQ...
# USD₮ jetton master (friendly form). Default is mainnet USD₮; the frontend needs
# it to build a USD₮ transfer.
USDT_JETTON_MASTER=EQCxE6mUtQJKFnGfaROTKOt1lZbDiiX1kCixRv7Nw2Id_sDs
# Pin the TON price (USD per TON) instead of asking PaulusAI. Empty = live rate.
# TON_USD_RATE_OVERRIDE=5.20

# --- PaulusAI validator (we call it) ----------------------------------------
PAULUS_BASE_URL=http://localhost:8000
# Must equal DP_PAYMENTS_TOKEN on the PaulusAI side.
PAULUS_VALIDATOR_TOKEN=shared-validator-token
PAULUS_HTTP_TIMEOUT=20

# --- Internal API (PaulusAI calls us for balance/debit) ---------------------
# Shared secret PaulusAI must present as "Authorization: Bearer <token>".
INTERNAL_API_TOKEN=shared-internal-token

# --- Invoices (priced in USD) -----------------------------------------------
MIN_TOPUP_USD=1
INVOICE_TTL_SECONDS=1800

# --- TON Connect manifest ---------------------------------------------------
TONCONNECT_APP_NAME=PaulusAI
TONCONNECT_APP_URL=https://your-mini-app.example.com
TONCONNECT_ICON_URL=https://your-mini-app.example.com/icon.png
